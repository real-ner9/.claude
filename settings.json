{
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "yakik-dev-toolkit@local": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "autoUpdatesChannel": "latest",
  "permissions": {
    "allow": [
      "Edit",
      "WebSearch",
      "Bash(git status:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git stash:*)",
      "Bash(git show:*)",
      "Bash(git rev-parse:*)",
      "Bash(git -C:*)",
      "Bash(npm run:*)",
      "Bash(npm audit:*)",
      "Bash(npm ls:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(ls:*)",
      "Bash(dir:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(findstr:*)",
      "Bash(claude:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git checkout .:*)",
      "Bash(git branch -D:*)",
      "Read(**/.env)",
      "Read(**/secrets/**)",
      "Read(**/*.key)"
    ]
  }
}
