# Credentials & secrets
.credentials.json

# Session data (device-specific, regenerated each session)
history.jsonl
stats-cache.json
todos/
shell-snapshots/

# Caches
cache/
paste-cache/

# Debug & telemetry
debug/
telemetry/
downloads/

# Session-bound plans, tasks, file history
plans/
tasks/
file-history/
sessions/

# Per-project data (paths are device-specific, e.g. C--Users-yakik-...)
# Each machine generates its own project dirs based on local paths.
# Memory inside projects/ is useful but inherently device-bound.
projects/
image-cache/

# Plugins (device-specific paths and caches)
plugins/installed_plugins.json
plugins/install-counts-cache.json
plugins/known_marketplaces.json
plugins/blocklist.json
plugins/cache/
plugins/marketplaces/

# Backups (auto-generated config snapshots)
backups/

# Local session permissions (device-specific)
.claude/

# Windows artifact
nul

# IDE
.idea/
